import torch
import numpy as np
from typing import List
from data.types import ObjectCandidate

FILL_MODES = ["fast", "ai_placeholder"]


class BGHoleFillNode:
    """
    오브젝트 제거 후 생긴 구멍을 메움.

    Phase 1: fast fill (OpenCV TELEA inpaint) 실제 동작.
    Phase 2: ai_placeholder → SD inpaint 어댑터 설계 및 연동 준비.
    Phase 3: AI fill 완성.
    """

    CATEGORY = "BG Spine Separator"
    RETURN_TYPES = ("IMAGE", "IMAGE")
    RETURN_NAMES = ("filled_background", "fill_debug")
    FUNCTION = "fill"

    @classmethod
    def INPUT_TYPES(cls):
        return {
            "required": {
                "image": ("IMAGE",),
                "object_candidates": ("BG_OBJECT_CANDIDATES",),
                "fill_mode": (FILL_MODES, {"default": "fast"}),
                "fill_radius": ("INT", {"default": 15, "min": 5, "max": 60}),
                "edge_preservation": ("FLOAT", {
                    "default": 0.8, "min": 0.0, "max": 1.0, "step": 0.05
                }),
            },
            "optional": {
                "selected_ids": ("STRING", {
                    "default": "",
                    "placeholder": "채울 obj id (쉼표 구분, 비우면 전체)",
                }),
                "debug_mode": ("BOOLEAN", {"default": False}),
            },
        }

    def fill(
        self,
        image,
        object_candidates,
        fill_mode,
        fill_radius,
        edge_preservation,
        selected_ids: str = "",
        debug_mode: bool = False,
    ):
        img_np = (image[0].numpy() * 255).astype(np.uint8)

        targets = self._filter_targets(object_candidates, selected_ids)
        combined_mask = self._combine_masks(targets, img_np.shape[:2])

        if fill_mode == "fast":
            filled = self._fast_fill(img_np, combined_mask, fill_radius)
        elif fill_mode == "ai_placeholder":
            # TODO Phase 2: SD inpaint 어댑터 연동
            print("[BGHoleFill] AI fill 미구현. fast fill로 폴백. (Phase 2에서 구현 예정)")
            filled = self._fast_fill(img_np, combined_mask, fill_radius)
        else:
            filled = img_np.copy()

        if debug_mode:
            print(f"[BGHoleFill] mode={fill_mode} radius={fill_radius} targets={len(targets)}")

        from utils.debug_utils import make_hole_fill_debug
        debug_vis = make_hole_fill_debug(img_np, combined_mask, filled)

        filled_t = torch.from_numpy(filled.astype(np.float32) / 255.0).unsqueeze(0)
        debug_t = torch.from_numpy(debug_vis.astype(np.float32) / 255.0).unsqueeze(0)

        return (filled_t, debug_t)

    def _filter_targets(self, candidates, selected_ids_str: str):
        if not selected_ids_str.strip():
            return candidates
        ids = {s.strip() for s in selected_ids_str.split(",")}
        return [c for c in candidates if c.id in ids]

    def _combine_masks(self, candidates, shape):
        combined = np.zeros(shape, dtype=np.float32)
        for c in candidates:
            combined = np.maximum(combined, c.mask)
        return combined

    def _fast_fill(self, img_np: np.ndarray, mask: np.ndarray, radius: int) -> np.ndarray:
        """OpenCV TELEA 알고리즘 기반 hole fill."""
        import cv2
        mask_uint8 = (mask > 0.5).astype(np.uint8) * 255
        kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))
        mask_dilated = cv2.dilate(mask_uint8, kernel, iterations=2)
        img_bgr = cv2.cvtColor(img_np, cv2.COLOR_RGB2BGR)
        filled_bgr = cv2.inpaint(img_bgr, mask_dilated, radius, cv2.INPAINT_TELEA)
        return cv2.cvtColor(filled_bgr, cv2.COLOR_BGR2RGB)
